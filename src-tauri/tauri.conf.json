{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Koral Hub",
  "version": "0.2.1",
  "identifier": "com.koral.hub",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Koral Hub",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
